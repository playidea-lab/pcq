{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://playidea-lab.github.io/pcq/spec/schemas/pcq.run.envelope.schema.json",
  "title": "pcq.run.envelope",
  "description": "pcq run --json envelope for executed or config-only runs",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "cmd",
    "project_root",
    "runtime_cfg_path",
    "schema_version",
    "status"
  ],
  "properties": {
    "attribution": {
      "type": "object"
    },
    "cmd": {
      "type": "string"
    },
    "error": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    },
    "project_root": {
      "type": "string"
    },
    "runtime_cfg_path": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "failed",
        "config_only",
        "error"
      ]
    },
    "stderr_path": {
      "type": "string"
    },
    "stderr_tail": {
      "type": "string"
    },
    "stderr_tail_truncated": {
      "type": "boolean"
    },
    "stdout_path": {
      "type": "string"
    },
    "stdout_tail": {
      "type": "string"
    },
    "stdout_tail_truncated": {
      "type": "boolean"
    },
    "worker_spec": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "cpu": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "properties": {
            "model": {
              "type": [
                "string",
                "null"
              ]
            },
            "cores_physical": {
              "type": [
                "integer",
                "null"
              ]
            },
            "cores_logical": {
              "type": [
                "integer",
                "null"
              ]
            },
            "max_freq_mhz": {
              "type": [
                "integer",
                "null"
              ]
            }
          }
        },
        "memory": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "properties": {
            "total_gb": {
              "type": [
                "number",
                "null"
              ]
            }
          }
        },
        "accelerator": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "mps",
                "cuda",
                "cpu"
              ]
            },
            "gpus": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "model": {
                    "type": "string"
                  },
                  "vram_gb": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "cuda_version": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "torch_ordinal": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  }
                },
                "required": [
                  "model"
                ]
              }
            },
            "visible_devices": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "gpus"
          ]
        },
        "os": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "properties": {
            "system": {
              "type": "string"
            },
            "machine": {
              "type": "string"
            },
            "release": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "container": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "none",
                "docker",
                "k8s",
                "other"
              ]
            },
            "image": {
              "type": [
                "string",
                "null"
              ]
            },
            "detector_hint": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "detected",
            "declared",
            "merged"
          ]
        }
      },
      "required": [
        "schema_version",
        "accelerator",
        "container",
        "source"
      ]
    }
  },
  "x-pcq-schema-version": 1,
  "x-pcq-additive-only": true
}
