{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://playidea-lab.github.io/pcq/spec/schemas/pcq.describe_run.record.schema.json",
  "title": "pcq.describe_run.record",
  "description": "pcq describe-run --json for a readable RunRecord",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "decision_facts",
    "dirty",
    "epochs_completed",
    "output_dir",
    "partial",
    "schema_version",
    "status",
    "validation_status"
  ],
  "properties": {
    "artifacts": {
      "type": "array"
    },
    "artifacts_summary": {
      "type": "object"
    },
    "attribution": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "author": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "human",
                "agent"
              ]
            },
            "id": {
              "type": "string"
            },
            "persona_id": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "id"
          ]
        },
        "committer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "human",
                "agent"
              ]
            },
            "id": {
              "type": "string"
            },
            "persona_id": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "id"
          ]
        },
        "operator": {
          "type": "string"
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "schema_version",
        "author",
        "committer",
        "operator"
      ]
    },
    "attribution_author_kind": {
      "type": [
        "string",
        "null"
      ]
    },
    "attribution_committer_kind": {
      "type": [
        "string",
        "null"
      ]
    },
    "attribution_operator": {
      "type": [
        "string",
        "null"
      ]
    },
    "attribution_session_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "best": {
      "type": "object"
    },
    "best_epoch": {
      "type": "integer"
    },
    "best_value": {
      "type": "number"
    },
    "cmd": {
      "type": "string"
    },
    "decision_facts": {
      "type": "object"
    },
    "dirty": {
      "type": "boolean"
    },
    "duration_seconds": {
      "type": "number"
    },
    "epochs_completed": {
      "type": "integer"
    },
    "failure": {
      "type": "object"
    },
    "git_sha": {
      "type": "string"
    },
    "last": {
      "type": "object"
    },
    "last_epoch": {
      "type": "integer"
    },
    "last_value": {
      "type": "number"
    },
    "metrics_declared": {
      "type": "array"
    },
    "mode": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "output_dir": {
      "type": "string"
    },
    "parent_run_id": {
      "type": "string"
    },
    "parent_run_path": {
      "type": "string"
    },
    "partial": {
      "type": "boolean"
    },
    "platform": {
      "type": "string"
    },
    "python": {
      "type": "string"
    },
    "reproducibility_evidence": {
      "type": "object"
    },
    "run_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer"
    },
    "status": {
      "type": "string"
    },
    "target_metric": {
      "type": "string"
    },
    "validation_report_path": {
      "type": "string"
    },
    "validation_status": {
      "type": "string"
    },
    "worker_spec": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "type": "integer",
          "const": 1
        },
        "cpu": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "properties": {
            "model": {
              "type": [
                "string",
                "null"
              ]
            },
            "cores_physical": {
              "type": [
                "integer",
                "null"
              ]
            },
            "cores_logical": {
              "type": [
                "integer",
                "null"
              ]
            },
            "max_freq_mhz": {
              "type": [
                "integer",
                "null"
              ]
            }
          }
        },
        "memory": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "properties": {
            "total_gb": {
              "type": [
                "number",
                "null"
              ]
            }
          }
        },
        "accelerator": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "mps",
                "cuda",
                "cpu"
              ]
            },
            "gpus": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "model": {
                    "type": "string"
                  },
                  "vram_gb": {
                    "type": [
                      "number",
                      "null"
                    ]
                  },
                  "cuda_version": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "torch_ordinal": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  }
                },
                "required": [
                  "model"
                ]
              }
            },
            "visible_devices": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "gpus"
          ]
        },
        "os": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "properties": {
            "system": {
              "type": "string"
            },
            "machine": {
              "type": "string"
            },
            "release": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "container": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "none",
                "docker",
                "k8s",
                "other"
              ]
            },
            "image": {
              "type": [
                "string",
                "null"
              ]
            },
            "detector_hint": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "detected",
            "declared",
            "merged"
          ]
        }
      },
      "required": [
        "schema_version",
        "accelerator",
        "container",
        "source"
      ]
    },
    "worker_spec_accelerator_kind": {
      "type": [
        "string",
        "null"
      ]
    },
    "worker_spec_cpu_model": {
      "type": [
        "string",
        "null"
      ]
    },
    "worker_spec_gpu_model_0": {
      "type": [
        "string",
        "null"
      ]
    },
    "worker_spec_memory_gb": {
      "type": [
        "number",
        "null"
      ]
    }
  },
  "x-pcq-schema-version": 1,
  "x-pcq-additive-only": true
}
