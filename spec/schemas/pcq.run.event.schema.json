{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://playidea-lab.github.io/pcq/spec/schemas/pcq.run.event.schema.json",
  "title": "pcq.run.event",
  "description": "pcq run --jsonl newline-delimited event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "event",
    "schema_version",
    "seq",
    "time"
  ],
  "properties": {
    "cmd": {
      "type": "string"
    },
    "error": {
      "type": "string"
    },
    "event": {
      "type": "string",
      "enum": [
        "run.started",
        "run.completed",
        "run.failed",
        "run.error",
        "run.config_only",
        "stdout",
        "stderr",
        "metric"
      ]
    },
    "events_path": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    },
    "metrics": {
      "type": "object"
    },
    "project_root": {
      "type": "string"
    },
    "raw": {
      "type": "string"
    },
    "runtime_cfg_path": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer"
    },
    "seq": {
      "type": "integer"
    },
    "status": {
      "type": "string"
    },
    "stderr_path": {
      "type": "string"
    },
    "stdout_path": {
      "type": "string"
    },
    "stream": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "time": {
      "type": "string"
    }
  },
  "x-pcq-schema-version": 1,
  "x-pcq-additive-only": true
}
